# ── Apollo.io ────────────────────────────────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key_here

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional CTA for generate-copy (replaces placeholders in prompts/personalization.txt before Claude):
# GTM_BRIEF_CTA_BASE_URL=https://intel.nextbuildtech.com   # no trailing slash; replaces https://yourdomain.com
# GTM_BRIEF_HTML_FILENAME=elearning-brief.html              # default; use e.g. management-consulting-brief.html for another vertical
#
# Optional: lock email competitor names to the same pair as the static HTML brief (set BOTH or neither):
# GTM_REPORT_COMPETITOR_A=Docebo
# GTM_REPORT_COMPETITOR_B=Absorb LMS
# See docs/VERTICAL-BRIEF-AND-EMAIL.md

# ── Instantly ─────────────────────────────────────────────────────────────────
# API v2 key (Bearer) — https://developer.instantly.ai/getting-started/getting-started
# Needs scopes that include leads:create (or leads:all / all:all).
INSTANTLY_API_KEY=your_instantly_api_v2_key_here
# Create a campaign in Instantly first, then paste the campaign UUID from the URL
INSTANTLY_CAMPAIGN_ID=your_campaign_id_here

# ── n8n (self-hosted) ─────────────────────────────────────────────────────────
# The webhook URL from your n8n reply-handler workflow (generated after import)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/gtm-reply

# ── Optional: Slack for hot-lead alerts ───────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
