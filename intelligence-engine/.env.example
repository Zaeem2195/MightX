# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Report generator model + thinking (Opus turbo default).
REPORT_MODEL=claude-opus-4-7
REPORT_THINKING_BUDGET_TOKENS=16000
# Analysis engine model + thinking (Opus turbo; used by analyse.js analyst + fact-check passes).
ANALYSIS_MODEL=claude-opus-4-7
ANALYSIS_THINKING_BUDGET_TOKENS=12000
# Quarterly summary model + thinking (Opus turbo).
QUARTERLY_SUMMARY_MODEL=claude-opus-4-7
QUARTERLY_SUMMARY_THINKING_BUDGET_TOKENS=14000

# ── Email Delivery ────────────────────────────────────────────────────────────
# Driver selection:
#   EMAIL_DRIVER=resend   → use Resend HTTPS API (recommended past ~10 clients)
#   EMAIL_DRIVER=smtp     → use nodemailer SMTP (local dev / Gmail)
# If unset: auto-select resend when RESEND_API_KEY is present, otherwise smtp.
EMAIL_DRIVER=

# Resend (https://resend.com). Free tier = 100/day, 3k/month. Verify your
# sending domain in Resend first; EMAIL_FROM must match a verified domain.
RESEND_API_KEY=
EMAIL_FROM=ci@yourdomain.com
EMAIL_FROM_NAME=Intelligence Briefing
EMAIL_REPLY_TO=

# SMTP fallback (works with Gmail, Outlook, or any SMTP provider).
# For Gmail: enable "App Passwords" in your Google account security settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=Intelligence Briefing
SMTP_FROM_EMAIL=you@gmail.com

# ── Optional: Apify (premium collectors) ─────────────────────────────────────
# When set: news full-text, G2 reviews, LinkedIn company, website change monitor,
# job description enrichment, and optional Glassdoor (if enabled in client config).
# Omit for free RSS / careers-only runs.
APIFY_API_TOKEN=

# Set to 1 to also scrape LinkedIn company posts (extra Apify usage).
APIFY_FETCH_LINKEDIN_POSTS=1

# Optional: ms between Apify LinkedIn company URL attempts (default 4500). Helps avoid LinkedIn rate limits.
# APIFY_LINKEDIN_RETRY_DELAY_MS=4500

# ── Optional: Ops Slack webhook (validation gate alerts) ─────────────────────
# If set, validate-report.js will POST here when a report is blocked from
# delivery so you find out before the client notices silence on Monday.
OPS_SLACK_WEBHOOK_URL=

# ── Optional: SEC EDGAR (free, no key) ───────────────────────────────────────
# SEC requires a descriptive User-Agent on every request. Use your real org +
# contact email. Only used by the SEC 8-K collector when a competitor has a
# secCik or secTicker configured.
SEC_EDGAR_USER_AGENT=YourOrg Intelligence (contact@yourdomain.com)

# ── Optional: n8n webhook to trigger a run manually ──────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/intelligence-run
